# Pull latest stable py-numba (0.65.1) + py-llvmlite (0.47.0), which support
# llvm@20 (the newest LLVM py-llvmlite supports; acorn -> py-numba pulls it in).
# The upstream commit doesn't cherry-pick cleanly onto this image's older
# spack-packages, so check out the two package files at that commit instead.
git remote add upstream https://github.com/spack/spack-packages.git 2>/dev/null || true
git fetch --depth 50 upstream ce14512cd8b82e4e4f45367916d37f59dba08606
git checkout ce14512cd8b82e4e4f45367916d37f59dba08606 -- \
  repos/spack_repo/builtin/packages/py_numba/package.py \
  repos/spack_repo/builtin/packages/py_llvmlite/package.py

# edm4hep@main uses a non-numeric version component ("main"), which breaks the
# current url_for_version implementation under Spack's SBOM hook (%d formatting).
# Patch it to fall back to the git URL for non-numeric versions.
git apply <<'PATCH'
diff --git a/repos/spack_repo/builtin/packages/edm4hep/package.py b/repos/spack_repo/builtin/packages/edm4hep/package.py
--- a/repos/spack_repo/builtin/packages/edm4hep/package.py
+++ b/repos/spack_repo/builtin/packages/edm4hep/package.py
@@ -125,6 +125,10 @@ class Edm4hep(CMakePackage):
         """
         base_url = self.url.rsplit("/", 1)[0]
 
+        # Branch-like versions (e.g. "main") are non-numeric and cannot be
+        # formatted with %d below. For those, use the repository URL directly.
+        if not all(str(component).isdigit() for component in version):
+            return self.git
         if len(version) == 1:
             major = version[0]
             minor, patch = 0, 0
PATCH
